*.pbxuser
!default.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
*.xccheckout
*.moved-aside
DerivedData/
*.hprof
*.ipa
*.dSYM.zip
*.dSYM
Pods/

# --- Certificats & clés sensibles ---
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem
*.orig.*

# --- Kotlin (Android / tooling) ---
.kotlin/

# --- React Native ---
*.jsbundle
*.bundle

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini

