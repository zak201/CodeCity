DATABASE_URL="file:./dev.db"
PORT=3050

# Secret de signature des jetons JWT (auth). METTRE une valeur longue et
# aléatoire en production. Un défaut de dev est prévu si absent.
JWT_SECRET=change-me-with-a-long-random-string

# LOG — IA tutrice (Claude API). Laisser vide désactive l'IA temps réel :
# l'app bascule alors automatiquement sur la base de connaissances locale.
ANTHROPIC_API_KEY=
# Modèle utilisé pour LOG (par défaut : claude-haiku-4-5, rapide et économique).
LOG_MODEL=claude-haiku-4-5
